---
import Search from '@/components/Search.astro';
import '../styles/global.css';
interface Props {
  title: string;
  description?: string;
}
const { title, description = 'Maritime news, decoded.' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {/* Self-referencing canonical at the apex host so Google consolidates the
        apex / www / v2 duplicates onto one URL (fixes GSC "Duplicate without
        user-selected canonical", 2026-06-12). Astro.site = the config `site`. */}
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site).href} />
    <style>
      :root {
        --bg:#0b1020; --fg:#e7ecf3; --muted:#8a96a8;
        --accent:#4aa3ff; --border:#1e2a45; --card:#141b30;
      }
      * { box-sizing: border-box; }
      body {
        margin:0;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
        background:var(--bg); color:var(--fg); line-height:1.55;
      }
      a { color:var(--accent); text-decoration:none; }
      a:hover { text-decoration:underline; }
      .wrap { max-width: 820px; margin: 0 auto; padding: 24px 20px 80px; }
      header.site { border-bottom:1px solid var(--border); }
      header.site .wrap { padding-top:18px; padding-bottom:14px; }
      .brand { font-weight:800; font-size:20px; letter-spacing:-0.02em; }
      .muted { color:var(--muted); }
      .tag {
        display:inline-block; font-size:11px; padding:2px 8px;
        border:1px solid #25324f; border-radius:999px;
        color:var(--muted); margin-right:6px; margin-bottom:4px;
      }
      footer.site {
        border-top:1px solid var(--border); margin-top:40px;
        font-size:12px; color:var(--muted);
      }
      footer.site .wrap { padding-top:14px; padding-bottom:24px; }
    </style>
  </head>
  <body>
    <header class="site">
      <div class="wrap">
        <a href="/" class="brand">Maritime Reader <span class="muted" style="font-weight:400;font-size:13px;">v2</span></a>
      </div>
    </header>
    <main class="wrap">
      <Search />
      <slot />
    </main>
    <footer class="site">
      <div class="wrap">
        Static build · pre-rendered from Supabase · no runtime AI · no runtime DB.
      </div>
    </footer>
  </body>
</html>
