      var d = r && r.__data && r.__data.meta ? r.__data.meta.date : null;
      var t = d ? new Date(d).getTime() : NaN;
      return isNaN(t) ? -Infinity : t; // undated sinks to the bottom
    }
    // Pull the next `n` globally date-newest, de-duplicated results.
    async function pullNext(n) {
      var out = [];
      while (out.length < n) {
        await resolveHeads();
        var best = -1, bestT = 0;
        for (var i = 0; i < streams.length; i++) {
          var r = streams[i].results[streams[i].idx];
          if (!r) continue;
          var t = dateOf(r);
          if (best === -1 || t > bestT) { best = i; bestT = t; }
        }
        if (best === -1) break; // all streams exhausted
        var s = streams[best];
        var chosen = s.results[s.idx];
        s.idx++; // advance even on a dup, so the merge always makes progress
        var u = chosen.__data && chosen.__data.url;
        if (u) { if (seenUrls[u]) continue; seenUrls[u] = 1; }
        out.push(chosen);
      }
      return out;
    }
    async function renderMore() {
      var batch = await pullNext(PAGE);
