      moreBtn.classList.toggle('hidden', !hasMore);
    }
    // Related-terms checkbox panel for the matched key. All ON by default; toggling
    // a checkbox updates relSel + re-runs. Rebuilt only when the key changes (so the
    // DOM checkbox state + open/closed state persist while the user keeps typing).
    // Reuses the source-dropdown's safelisted classes (JS-built → not Tailwind-scanned).
    function updateRelatedBtn() {
      if (relatedBtn) relatedBtn.textContent = 'Related terms (' + relSel.size + ') ▾';
    }
    function renderRelatedPanel(rel) {
      if (!relatedWrap) return;
      if (!rel) {
        relatedWrap.classList.add('hidden');
        if (relatedPanel) relatedPanel.classList.add('hidden');
        if (relatedList) relatedList.innerHTML = '';
        return;
      }
      relatedWrap.classList.remove('hidden');
      if (relatedTitle) relatedTitle.textContent = 'Related to “' + rel.key + '”';
      var html = '';
      rel.terms.forEach(function (term) {
        html += '<label class="flex items-center gap-2 text-sm py-0.5 px-1 rounded hover:bg-slate-50 cursor-pointer">' +
          '<input type="checkbox" class="accent-sky-600" data-rel="' + esc(term) + '"' + (relSel.has(term) ? ' checked' : '') + '>' +
          '<span class="truncate">' + esc(term) + '</span></label>';
      });
      relatedList.innerHTML = html;
      Array.prototype.forEach.call(relatedList.querySelectorAll('input[data-rel]'), function (cb) {
        cb.addEventListener('change', function () {
          var term = cb.getAttribute('data-rel');
          if (cb.checked) relSel.add(term); else relSel.delete(term);
          updateRelatedBtn();
          run();
        });
      });
      updateRelatedBtn();
    }

    async function run() {
      if (!pf) return;
      writeURL();
      updateChipStates();
      renderActiveChips();
      var active = isActive();
      var staticFeed = document.getElementById('static-feed');
      if (staticFeed) staticFeed.hidden = active;
      resultsWrap.classList.toggle('hidden', !active);
      activeEl.classList.toggle('hidden', !active);
      activeEl.classList.toggle('flex', active);
      if (!active) { resultsEl.innerHTML = ''; streams = []; shown = 0; relKey = null; relSel = new Set(); renderRelatedPanel(null); if (loadEl) loadEl.classList.add('hidden'); return; }

      // Show the loading state IMMEDIATELY so a search/filter never looks like a
      // blank/broken screen during the wait (cold cdn index load measured ~9.5s
      // first time, ~1.6s warm). Cleared once results render.
      resultsEl.innerHTML = ''; shown = 0; seenUrls = {};
      emptyEl.classList.add('hidden');
      if (loadEl) loadEl.classList.remove('hidden');

      var token = {}; pending = token;

      // Related-terms dropdown: prefix-match the typed text to a synonym key.
      // Rebuild + AUTO-OPEN only when the matched key changes (so the user's
      // checkbox toggles + open/closed state persist while they keep typing).
      // A new key starts with ALL related terms checked; only checked terms join
      // the search (live — user 2026-06-10). Multi-word ones search as phrases.
      var rel = relatedFor(sel.q);
      var key = rel ? rel.key : null;
      if (key !== relKey) {
        relKey = key;
        relSel = rel ? new Set(rel.terms) : new Set();
        renderRelatedPanel(rel);
        if (rel && relatedPanel) relatedPanel.classList.remove('hidden'); // auto-open on a new match
      }
      var terms = [sel.q];
      if (rel) rel.terms.forEach(function (t) { if (relSel.has(t)) terms.push(/\s/.test(t) ? '"' + t + '"' : t); });

      // Newest-first for ALL results — browse AND text queries (user, 2026-06-08).
      // Pagefind's `sort` overrides relevance; the date key is in the index (B3).
      var opts = { filters: filtersObj() };
      if (DATE_SORT) opts.sort = { date: 'desc' };

      var searches;
      try { searches = await Promise.all(terms.map(function (t) { return pf.search(t || null, opts); })); }
      catch (e) { searches = null; }
      if (pending !== token) return; // a newer search will manage the loading state
      if (!searches) { if (loadEl) loadEl.classList.add('hidden'); return; }

      streams = searches.map(function (s) { return { results: s.results, idx: 0 }; });

      // Count = unique fragment ids across all streams (cheap, no data()). Base/
      // delta overlap leaves the same ~1% inflation the single-search path had.
      var idset = {};
      streams.forEach(function (s) { for (var i = 0; i < s.results.length; i++) idset[s.results[i].id] = 1; });
      var total = Object.keys(idset).length;
      countEl.textContent = total.toLocaleString('en-US') + ' result' + (total === 1 ? '' : 's');

      // A data()/render failure must never blank the feed — render whatever resolved.
      try { await renderMore(); } catch (e) {}
      if (pending !== token) return;
      if (loadEl) loadEl.classList.add('hidden');
      emptyEl.classList.toggle('hidden', total > 0);
    }

    moreBtn.addEventListener('click', async function () { await renderMore(); });
    clearBtn.addEventListener('click', function () {
      sel.q = ''; qEl.value = ''; ALL_FACETS.forEach(function (k) { sel[k] = new Set(); }); syncQClear(); run();
    });
    if (qClear) qClear.addEventListener('click', function () {
      sel.q = ''; qEl.value = ''; syncQClear(); qEl.focus(); run();
    });
    qEl.addEventListener('input', function () {
      sel.q = qEl.value.trim();
      syncQClear();
      clearTimeout(debounce);
      // Short queries match a huge slice of the 51k index — heavy + useless, and
      // 1-2 chars froze a slower machine (2026-06-08). Require 3+ chars; 0 (cleared)
      // still runs to reset back to the static feed. EXCEPTION: a 2-char query that
      // is a known synonym-map key (GA, CP, BV, LR, NK) is allowed — its expansion
      // gives real results.
      if (sel.q.length > 0 && sel.q.length < 3 && !SYNONYMS[sel.q.toLowerCase()]) return;
      debounce = setTimeout(run, 300);
    });
    // Source panel: toggle open, re-render with current selection on open, filter
    // as you type, close on outside-click. Checkbox changes are wired in
    // renderSourceList (each toggles sel.source + run()).
    if (sourceBtn) sourceBtn.addEventListener('click', function (e) {
      e.stopPropagation();
      var open = sourcePanel.classList.contains('hidden');
      if (open) { renderSourceList(sourceQ ? sourceQ.value : ''); sourcePanel.classList.remove('hidden'); if (sourceQ) sourceQ.focus(); }
      else sourcePanel.classList.add('hidden');
    });
    if (sourceQ) sourceQ.addEventListener('input', function () { renderSourceList(sourceQ.value); });
    if (sourcePanel) sourcePanel.addEventListener('click', function (e) { e.stopPropagation(); });
    // Related-terms dropdown: button toggles it; clicks inside don't close it.
    if (relatedBtn) relatedBtn.addEventListener('click', function (e) { e.stopPropagation(); if (relatedPanel) relatedPanel.classList.toggle('hidden'); });
    if (relatedPanel) relatedPanel.addEventListener('click', function (e) { e.stopPropagation(); });
    document.addEventListener('click', function () {
      if (sourcePanel) sourcePanel.classList.add('hidden');
      if (relatedPanel) relatedPanel.classList.add('hidden');
    });
    window.addEventListener('popstate', function () { readURL(); run(); });

    async function init() {
      try {
        pf = await import((base || '') + '/_pagefind/pagefind.js');
        await pf.options({ baseUrl: '/' });
        await pf.init();
        // Merge the DELTA index (recent ~2 weeks, rebuilt every 3h) on top of the
        // static BASE index (full archive, rebuilt weekly) → search stays ~3h-fresh
        // without re-reading all 51k rows from Nano. baseUrl:'/' so delta result
        // URLs resolve to the real /article/<id>/ detail pages, not /_pagefind-delta/…
        // (measured 2026-06-08). Wrapped: if the delta isn't deployed yet, base-only
        // search still works. Overlap with base is deduped at render (by result.url).
        try { await pf.mergeIndex((base || '') + '/_pagefind-delta', { baseUrl: '/' }); }
        catch (e) { /* delta not deployed yet — base-only search is fine */ }
        var avail = await pf.filters(); // ONE call (post-merge) — builds the facet UI
        buildFacetsOnce(avail);
        readURL();
        syncQClear();
        updateChipStates();
        if (isActive()) run();
        // NOTE: no eager "warming" search here. A throwaway filter search on load
        // ran the heaviest Pagefind op (18k-result filter) concurrently with the
        // user's first keystrokes → on a slower machine/connection the tab went
        // "not responding" (reported 2026-06-08, appeared right after warming was
        // added). The first filter is slower without it (cold cdn index ≈ network,
        // async, not a freeze — the "Searching…" state covers it). Don't re-add.
      } catch (e) { /* index not built yet (dev) — static feed stays visible */ }
    }
    if ('requestIdleCallback' in window) requestIdleCallback(init, { timeout: 2000 });
    else setTimeout(init, 1);
  })();
</script>

<style is:global>
  /* NOTE: is:global (NOT scoped) is REQUIRED — the chips/pills/source buttons are
     created in JS (createElement / innerHTML) so they never get Astro's scope
     attribute; a scoped selector (.sf-chip[data-astro-cid]) would not match them.
     Class names are unique to this component, so global is safe. */

  /* Hide the browser's native type=search clear ×; we render our own (#sf-q-clear)
     pinned to the input edge — the UA pseudo-element can't be repositioned. */
  #sf-q::-webkit-search-cancel-button { -webkit-appearance: none; appearance: none; }
  #sf-q::-webkit-search-decoration { -webkit-appearance: none; appearance: none; }

  /* Sonar-ping loading animation (CSS-only, maritime theme, sky palette).
     3 staggered expanding rings + a solid center dot. When #sf-loading gets the
     `hidden` class (display:none) the whole subtree — animation included — is
     removed, so it disappears cleanly and burns no CPU while idle. */
  .sf-sonar {
    position: relative;
    width: 72px;
    height: 72px;
    margin: 0 auto;
  }
  .sf-sonar::after {
    content: '';
    position: absolute;
    inset: 44%;
    background: #0284c7; /* sky-600 */
    border-radius: 9999px;
  }
  .sf-sonar span {
    position: absolute;
    inset: 0;
    border: 2px solid #0ea5e9; /* sky-500 */
    border-radius: 9999px;
    opacity: 0;
    animation: sf-ping 1.8s cubic-bezier(0, 0.2, 0.8, 1) infinite;
  }
  .sf-sonar span:nth-child(2) { animation-delay: 0.6s; }
  .sf-sonar span:nth-child(3) { animation-delay: 1.2s; }
  @keyframes sf-ping {
    0%   { transform: scale(0.25); opacity: 0.85; }
    100% { transform: scale(1);    opacity: 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .sf-sonar span { animation-duration: 3.6s; }
  }

  /* Facet/source buttons — raised, pressable. Fast (70ms) so the color change
     on click is instant; hover lifts; the active/pressed state drops the shadow
     (inset) for a "pushed in" feel. Palette matches the site (slate). */
  .sf-chip {
    display: inline-flex; align-items: center; gap: 0.3rem;
    padding: 0.3rem 0.85rem;
    border-radius: 9999px;
    border: 1px solid #cbd5e1;            /* slate-300 */
    background: #fff; color: #334155;     /* slate-700 */
    font-size: 0.75rem; font-weight: 600; line-height: 1.1;
    cursor: pointer; white-space: nowrap;
    box-shadow: 0 1px 2px rgba(15, 23, 42, 0.10);
    transition: transform 70ms ease, box-shadow 70ms ease,
                background-color 70ms ease, color 70ms ease, border-color 70ms ease;
  }
  .sf-chip:hover { transform: translateY(-1px); box-shadow: 0 3px 8px rgba(15, 23, 42, 0.16); border-color: #94a3b8; }
  .sf-chip:active { transform: translateY(0); }
  .sf-chip.on {
    background: #0f172a; color: #fff; border-color: #0f172a;   /* slate-900, pressed */
    box-shadow: inset 0 1px 3px rgba(0, 0, 0, 0.35);
    transform: translateY(0);
  }
  .sf-chip.on:hover { transform: translateY(0); box-shadow: inset 0 1px 3px rgba(0, 0, 0, 0.35); border-color: #0f172a; }
  .sf-chip .cnt { opacity: 0.6; font-weight: 500; }

  /* Active-filter pills — bigger, easy × target. */
  .sf-pill {
    display: inline-flex; align-items: center; gap: 0.35rem;
    padding: 0.3rem 0.4rem 0.3rem 0.8rem;
    border-radius: 9999px;
    background: #fff; border: 1px solid #cbd5e1; color: #334155;
    font-size: 0.8rem; white-space: nowrap;
  }
  .sf-pill-x {
    display: inline-flex; align-items: center; justify-content: center;
    width: 1.25rem; height: 1.25rem; border-radius: 9999px;
    font-size: 1rem; line-height: 1; font-weight: 700; color: #94a3b8;
    cursor: pointer; transition: background-color 80ms ease, color 80ms ease;
  }
  .sf-pill-x:hover { color: #e11d48; background: #ffe4e6; }   /* rose */
</style>
