---
<section class="max-w-7xl 2xl:max-w-[100rem] mx-auto px-4 pt-4">
  {/* PROMINENT search (user 2026-06-09: the old faint bar read as decoration —
      "nobody realises they can search"). Magnifier icon + large field + a strong
      sky focus ring is the clearest "this is search" affordance (Algolia/docs
      pattern). Capped width + centered (full-bleed reads wrong). CUSTOM clear ×
      pinned to the right edge — the native type=search × can't be repositioned
      (UA pseudo-element), so it's hidden in is:global and we drive our own. */}
  <div class="max-w-3xl mx-auto">
    <div class="relative">
      <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
        class="pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400">
        <circle cx="11" cy="11" r="7"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line>
      </svg>
      <input
        id="sf-q"
        type="search"
        placeholder="Search 50,000+ maritime articles…"
        autocomplete="off"
        class="w-full pl-12 pr-11 py-3.5 rounded-xl border-2 border-slate-300 bg-white text-base shadow-sm transition placeholder:text-slate-400 focus:outline-none focus:border-sky-500 focus:ring-4 focus:ring-sky-100"
      />
      <button id="sf-q-clear" type="button" aria-label="Clear search"
        class="hidden absolute right-3 top-1/2 -translate-y-1/2 w-7 h-7 items-center justify-center rounded-full text-slate-400 hover:text-slate-700 hover:bg-slate-100 text-xl leading-none">×</button>
    </div>
    <p class="mt-2 text-center text-sm text-slate-500">Tip: wrap a phrase in quotes for an exact match — e.g. <span class="font-semibold text-slate-700">"port state control"</span></p>
  </div>

  {/* Related-terms dropdown — opens when the typed query matches (a prefix of) a
      synonym key. Checkbox list, all ON by default; only checked terms join the
      search. Closes on outside-click; the button reopens it. JS-built list. */}
  <div id="sf-related-wrap" class="hidden mt-3">
    <div class="relative inline-block">
      <button id="sf-related-btn" type="button" class="sf-chip">Related terms ▾</button>
      <div id="sf-related-panel" class="hidden absolute z-20 mt-1 w-80 bg-white border border-slate-200 rounded-lg shadow-lg p-2">
        <div id="sf-related-title" class="text-[10px] font-bold uppercase tracking-wide text-slate-400 px-1 pb-1">Related terms</div>
        <p class="px-1 pb-1.5 text-[11px] leading-snug text-slate-500 border-b border-slate-100 mb-1">All searched by default — untick any term you don't want included.</p>
        <div id="sf-related-list" class="max-h-72 overflow-y-auto pr-1"></div>
      </div>
    </div>
  </div>

  {/* Type / Segment / Theme chip rows — built ONCE at init from pagefind.filters() */}
  <div id="sf-facets" class="mt-3 space-y-2"></div>

  {/* Source — grouped MULTI-select checkbox panel (mirrors v1 SourceFilterDropdown) */}
  <div class="mt-2 flex items-start gap-3">
    <span class="text-xs font-bold uppercase tracking-wide text-slate-700 w-20 shrink-0 pt-1.5">Source</span>
    <div class="relative">
      <button id="sf-source-btn" type="button" class="sf-chip">All sources ▾</button>
      <div id="sf-source-panel" class="hidden absolute z-20 mt-1 w-72 bg-white border border-slate-200 rounded-lg shadow-lg p-2">
        <input id="sf-source-q" type="text" placeholder="Filter sources…" class="w-full px-2 py-1.5 mb-2 rounded border border-slate-300 text-xs focus:outline-none focus:border-sky-400" />
        <div id="sf-source-list" class="max-h-72 overflow-y-auto pr-1"></div>
      </div>
    </div>
  </div>
  {/* Tailwind safelist: these classes are built inside the is:inline script
      (sf-source-list items) which Tailwind does NOT scan, so reference them here. */}
  <div hidden class="text-[10px] font-bold uppercase tracking-wide text-slate-400 mt-2 mb-1 px-1 flex items-center gap-2 text-sm py-0.5 rounded hover:bg-slate-50 cursor-pointer truncate accent-sky-600"></div>

  {/* Active selections — bordered box so the user clearly sees their active
      filters; each removable via its ×, plus a prominent Clear all */}
  <div id="sf-active" class="mt-3 hidden flex-wrap items-center gap-3 rounded-lg border border-slate-200 bg-slate-50 px-4 py-3">
    <span id="sf-count" class="text-sm font-bold text-slate-900"></span>
    <div id="sf-terms" class="hidden flex-wrap items-center gap-2"></div>
    <div id="sf-chips" class="flex flex-wrap gap-2"></div>
    <button id="sf-clear" class="shrink-0 inline-flex items-center px-3 py-1 rounded-full border border-rose-300 text-rose-600 text-xs font-semibold hover:bg-rose-50 transition">Clear all</button>
  </div>
</section>

<section id="sf-results-wrap" class="max-w-7xl 2xl:max-w-[100rem] mx-auto px-4 py-6 hidden">
  <div id="sf-loading" class="hidden text-center py-16">
    <div class="sf-sonar" aria-hidden="true"><span></span><span></span><span></span></div>
    <p class="text-xl font-semibold text-slate-600 tracking-tight mt-5">Searching the archive…</p>
  </div>
  {/* GLOBAL sort toggle — a single sliding switch that drives the order of the
      WHOLE result set (Best + Broader + the single/ungrouped list). Left = relevance
      (sortPref=null), right = newest (sortPref='date'). It is ONE element that run()
      relocates per render: directly below the "Best matches" heading for grouped
      queries, or at the top of #sf-results for single/ungrouped queries. Hidden when
      there are no results. Clicking the track OR either label toggles. */}
  <div id="sf-sort" class="hidden">
    <span id="sf-sort-rel" class="sf-sort-lbl">Most relevant first</span>
    <button id="sf-sort-track" type="button" role="switch" aria-checked="false" aria-label="Sort order">
      <span class="sf-sort-thumb"></span>
    </button>
    <span id="sf-sort-date" class="sf-sort-lbl">Newest first</span>
  </div>
  {/* Grouped results: Best matches (exact phrase / topic) then Broader matches (words appear separately) */}
  <div id="sf-best-wrap" class="hidden">
    <h3 class="sf-group-label">Best matches <span class="sf-group-sub">Closest matches to your search</span></h3>
    <div id="sf-best" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4"></div>
    <div class="mt-4 mb-8 text-center"><button id="sf-best-more" class="hidden px-4 py-2 rounded-lg border border-slate-300 text-sm text-slate-700 hover:border-slate-400">Load more</button></div>
  </div>
  <div id="sf-broader-wrap" class="hidden">
    <h3 class="sf-group-label">Broader matches <span class="sf-group-sub">Your words appear, but maybe not together — less focused</span></h3>
    <div id="sf-broader" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4"></div>
    <div class="mt-4 text-center"><button id="sf-broader-more" class="hidden px-4 py-2 rounded-lg border border-slate-300 text-sm text-slate-700 hover:border-slate-400">Load more</button></div>
  </div>
  {/* Ungrouped results (single-word / quoted queries) */}
  <div id="sf-results" class="hidden grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4"></div>
  <div class="mt-6 text-center">
    <button id="sf-more" class="hidden px-4 py-2 rounded-lg border border-slate-300 text-sm text-slate-700 hover:border-slate-400">Load more</button>
    <p id="sf-empty" class="hidden p-12 text-sm text-slate-600">No results match your search and filters.</p>
  </div>
</section>

<script is:inline define:vars={{ base }}>
  (function () {
    // NOTE: date sort uses data-pagefind-sort="date" (in the regenerated index since
    // B3, 2026-06-08). Sort mode is now chosen per-run in run() (relevance for plain
    // text queries, date for browse / multi-term chip merges + the "Newest" toggle) —
    // see the SORT MODE block. Requesting sort:{date} on an index lacking the key
    // returns a right count but 0 rendered cards, so never use date sort pre-regen.
    var CHIP_FACETS = ['type', 'segment', 'theme']; // source is a dropdown
    var ALL_FACETS = ['type', 'segment', 'theme', 'source'];
    var FACET_LABEL = { type: 'Type', segment: 'Segment', theme: 'Theme' };
    var TYPE_LABEL = { news: 'News', press_release: 'Press', pi_circular: 'P&I', class_notice: 'Class',
      regulation: 'Regulation', market_report: 'Market', casualty_report: 'Casualty', psc_report: 'PSC' };
    var PAGE = 20;

    // Source grouping — ported verbatim from v1 components/v3/SourceFilterDropdown.tsx
    var SRC_GROUP_ORDER = ['news', 'pi', 'psc', 'magazines', 'youtube', 'others'];
    var SRC_GROUP_LABELS = { news: 'Marine News', pi: 'P&I Clubs', psc: 'Port State Control',
      magazines: 'Magazines', youtube: 'YouTube', others: 'Others' };
    var PI_NAMES = { 'Gard': 1, 'Gard — Hot topics': 1, 'Skuld': 1, 'UK P&I Club': 1, 'Britannia P&I': 1,
      'Steamship Mutual': 1, 'NorthStandard': 1, 'Swedish Club': 1, 'West of England': 1,
      'American P&I Club': 1, 'Japan P&I Club': 1, 'London P&I Club': 1, "Shipowners' Club": 1 };
    var PSC_NAMES = { 'Paris MOU': 1, 'Tokyo MOU': 1, 'Caribbean MOU': 1, 'Mediterranean MoU': 1,
      'Black Sea MoU Detentions': 1, 'Black Sea MoU News': 1 };
    var MAGAZINE_NAMES = { 'ABS Newly Classed Vessels': 1, 'ABS Rules & Guides Highlights': 1, 'ABS Regulatory Lessons': 1 };
    var OTHER_NAMES = { 'ABS': 1, 'BIMCO': 1, 'Polish Register of Shipping': 1, 'RightShip Insights': 1 };
    function srcGroupOf(name) {
      if (/\(YouTube\)\s*$/i.test(name)) return 'youtube';
      if (MAGAZINE_NAMES[name]) return 'magazines';
      if (OTHER_NAMES[name]) return 'others';
      if (PSC_NAMES[name]) return 'psc';
      if (PI_NAMES[name]) return 'pi';
      return 'news';
    }

    var qEl = document.getElementById('sf-q');
    var facetsEl = document.getElementById('sf-facets');
    var sourceBtn = document.getElementById('sf-source-btn');
    var sourcePanel = document.getElementById('sf-source-panel');
    var sourceQ = document.getElementById('sf-source-q');
    var sourceList = document.getElementById('sf-source-list');
    var sourceCounts = {}; // name -> count, from pf.filters() at init
    var resultsWrap = document.getElementById('sf-results-wrap');
    var resultsEl = document.getElementById('sf-results');
    var moreBtn = document.getElementById('sf-more');
    var emptyEl = document.getElementById('sf-empty');
    var loadEl = document.getElementById('sf-loading');
    var activeEl = document.getElementById('sf-active');
    var countEl = document.getElementById('sf-count');
    var termsEl = document.getElementById('sf-terms');
    var chipsEl = document.getElementById('sf-chips');
    var clearBtn = document.getElementById('sf-clear');
    var qClear = document.getElementById('sf-q-clear');
    var relatedWrap = document.getElementById('sf-related-wrap');
    var relatedBtn = document.getElementById('sf-related-btn');
    var relatedPanel = document.getElementById('sf-related-panel');
    var relatedTitle = document.getElementById('sf-related-title');
    var relatedList = document.getElementById('sf-related-list');
    var sortWrap = document.getElementById('sf-sort');
    var sortRelLbl = document.getElementById('sf-sort-rel');
    var sortDateLbl = document.getElementById('sf-sort-date');
    var sortTrack = document.getElementById('sf-sort-track');
    var bestWrap = document.getElementById('sf-best-wrap');
    var bestEl = document.getElementById('sf-best');
    var bestMore = document.getElementById('sf-best-more');
    var broaderWrap = document.getElementById('sf-broader-wrap');
    var broaderEl = document.getElementById('sf-broader');
    var broaderMore = document.getElementById('sf-broader-more');
    if (!qEl) return;

    // Custom search-clear × (native type=search × is hidden in is:global; it
    // can't be repositioned). Visible only when the input has text.
    function syncQClear() {
      if (!qClear) return;
      var has = qEl.value.length > 0;
      qClear.classList.toggle('hidden', !has);
      qClear.classList.toggle('flex', has);
    }

    var pf = null, pending = null, debounce = null;
    var sel = { q: '', type: new Set(), segment: new Set(), theme: new Set(), source: new Set() };
    // Result groups for the current search (set by run()): single (ungrouped), or
    // Best + Broader. Each is a group object {streams, byDate, seen, excludeIds}.
    var curSingle = null, curBest = null, curBroader = null;
    // ACTIVE = the current search's terms with their matched result-id sets, used for
    // the per-card "Matched by" tags and the per-term result counts (chips + pills).
    // Populated from the same pf.search() calls we already run (no extra searches).
    var ACTIVE = [];
    function resetActive() { ACTIVE = []; }
    function addActive(term, results) {
      if (!term) return;
      var label = String(term).replace(/^"|"$/g, '');
      var e = null; for (var i = 0; i < ACTIVE.length; i++) { if (ACTIVE[i].label === label) { e = ACTIVE[i]; break; } }
      if (!e) { e = { label: label, ids: {} }; ACTIVE.push(e); }
      for (var j = 0; j < results.length; j++) e.ids[results[j].id] = 1;
    }
    function matchedFor(id) { var out = []; for (var i = 0; i < ACTIVE.length; i++) if (ACTIVE[i].ids[id]) out.push(ACTIVE[i].label); return out; }
    function activeCount(label) { for (var i = 0; i < ACTIVE.length; i++) if (ACTIVE[i].label === label) return Object.keys(ACTIVE[i].ids).length; return 0; }
    var relKey = null;       // identity (title) of the currently matched panel, or null
    var relSel = new Set();  // related/narrow terms the user has SELECTED to include
    var sortPref = null;     // null = auto (relevance for text queries); 'date' = user chose Newest

    // 3-layer maritime search map (Phase A 2026-06-10): loaded at runtime from a
    // static JSON (/maritime-search-map.json) — NOT inlined into the HTML. Matching:
    //   trigger    (exact, or >=3-char prefix → SHORTEST trigger) → topic's `related`
    //   narrow-key (exact)                                        → that narrow set only
    //   related    (exact)                                        → its narrow set if any, else nothing
    // blockedSingleWordRelatedTerms are filtered from every chip list. Quoted → nothing.
    // Prefix only on triggers (the as-you-type discovery path: "spe"→"speed claim");
    // related/narrow are exact (the user already typed the specific term) so searching
    // a related term does NOT re-open the whole parent group (no result pollution).
    var MAP = null;            // topicKey -> {triggers, related, narrow}
    var BLOCKED = {};          // normalized blocked single word -> 1
    var TRIGGERS = {};         // normTrigger -> {topic, label}
    var TRIGGER_NORMS = [];    // [normTrigger] for the prefix scan
    var RELATED = {};          // normRelatedTerm -> {topic, term}
    var NARROW = {};           // normNarrowKey -> {topic, key}
    function isQuoted(q) { return /^".*"$/.test(q); }
    // Fold Turkish-keyboard letters to their ASCII English equivalents so a TR user
    // typing an English term still matches. MEASURED 2026-06-12: Pagefind already
    // case-folds + handles dotted "İ" (İncident == incident), but the dotless "ı"
    // did NOT match (ıncident=1 vs incident=2830). Folding all TR letters fixes ı and
    // is a no-op where Pagefind already folds. Applied to the SEARCH query only — the
    // box / pills still show exactly what the user typed.
    function foldTr(q) {
      return (q || '')
        .replace(/İ/g, 'i').replace(/ı/g, 'i')
        .replace(/Ş/g, 's').replace(/ş/g, 's')
        .replace(/Ğ/g, 'g').replace(/ğ/g, 'g')
        .replace(/Ü/g, 'u').replace(/ü/g, 'u')
        .replace(/Ö/g, 'o').replace(/ö/g, 'o')
        .replace(/Ç/g, 'c').replace(/ç/g, 'c');
    }
    function norm(q) { return foldTr(q || '').toLowerCase().replace(/\s+/g, ' ').trim(); }
    function buildMapIndex(data) {
      MAP = (data && data.topics) || {};
      BLOCKED = {};
      ((data && data.blockedSingleWordRelatedTerms) || []).forEach(function (w) { BLOCKED[norm(w)] = 1; });
      TRIGGERS = {}; TRIGGER_NORMS = []; RELATED = {}; NARROW = {};
      Object.keys(MAP).forEach(function (tk) {
        var t = MAP[tk] || {};
        (t.triggers || []).forEach(function (tr) { var n = norm(tr); if (!TRIGGERS[n]) { TRIGGERS[n] = { topic: tk, label: tr }; TRIGGER_NORMS.push(n); } });
        (t.related || []).forEach(function (r) { var n = norm(r); if (!RELATED[n]) RELATED[n] = { topic: tk, term: r }; });
        if (t.narrow) Object.keys(t.narrow).forEach(function (nk) { var n = norm(nk); if (!NARROW[n]) NARROW[n] = { topic: tk, key: nk }; });
      });
    }
    function filterBlocked(arr) { return (arr || []).filter(function (x) { return !BLOCKED[norm(x)]; }); }
    // Returns { title, terms } for the matched panel, or null.
    function relatedFor(q) {
      if (!q || isQuoted(q) || !MAP) return null;
      var t = norm(q);
      if (!t) return null;
      // seeds = strong "Best" seed phrases the match itself implies (topic triggers,
      // or the matched narrow/related key) — fed into Best alongside the selected chips.
      if (TRIGGERS[t]) { var m = TRIGGERS[t]; return { title: m.label, terms: filterBlocked(MAP[m.topic].related), seeds: (MAP[m.topic].triggers || []).slice(), exact: !!MAP[m.topic].exact }; }
      if (NARROW[t]) { var nn = NARROW[t]; return { title: nn.key, terms: filterBlocked(MAP[nn.topic].narrow[nn.key]), seeds: [nn.key] }; }
      if (RELATED[t]) { var rr = RELATED[t]; var nar = MAP[rr.topic].narrow && MAP[rr.topic].narrow[rr.term]; return nar ? { title: rr.term, terms: filterBlocked(nar), seeds: [rr.term] } : null; }
      // A broad single word ("cargo", "inspection", "crew"...) must NOT prefix-expand
      // into some topic ("cargo" → "cargo tank"). Exact triggers were already handled
      // above, so a blocked word that is also a real trigger (e.g. "pollution") still works.
      if (BLOCKED[t]) return null;
      if (t.length >= 3) {
        var best = null;
        for (var i = 0; i < TRIGGER_NORMS.length; i++) { var tn = TRIGGER_NORMS[i]; if (tn.indexOf(t) === 0 && (!best || tn.length < best.length)) best = tn; }
        if (best) { var bm = TRIGGERS[best]; return { title: bm.label, terms: filterBlocked(MAP[bm.topic].related), seeds: (MAP[bm.topic].triggers || []).slice(), exact: !!MAP[bm.topic].exact }; }
      }
      return null;
    }
    function isShortExactTrigger(q) { return !!(MAP && TRIGGERS[norm(q)]); }

    function isActive() { return !!sel.q || ALL_FACETS.some(function (k) { return sel[k].size > 0; }); }

    function readURL() {
      var p = new URLSearchParams(location.search);
      sel.q = p.get('q') || '';
      ALL_FACETS.forEach(function (k) { sel[k] = new Set((p.get(k) || '').split(',').filter(Boolean)); });
      qEl.value = sel.q;
      // source state is reflected by updateChipStates (button) + renderSourceList
      // (checkboxes, re-rendered when the panel opens) — no select to sync.
    }
    function writeURL() {
      var p = new URLSearchParams();
      if (sel.q) p.set('q', sel.q);
      ALL_FACETS.forEach(function (k) { if (sel[k].size) p.set(k, Array.from(sel[k]).join(',')); });
      var qs = p.toString();
      history.replaceState(null, '', qs ? location.pathname + '?' + qs : location.pathname);
    }

    // OR within a group → Pagefind {any:[...]}. AND across groups is implicit.
    function filtersObj() {
      var f = {};
      ALL_FACETS.forEach(function (k) { if (sel[k].size) f[k] = { any: Array.from(sel[k]) }; });
      return f;
    }

    function esc(s) { return (s == null ? '' : String(s)).replace(/[&<>"]/g, function (c) {
      return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]; }); }
    function ago(iso) {
      var t = new Date(iso).getTime(); if (isNaN(t)) return '';
      var m = Math.max(0, (Date.now() - t) / 1000) / 60;
      if (m < 1) return 'just now'; if (m < 60) return Math.floor(m) + 'm ago';
      var h = m / 60; if (h < 24) return Math.floor(h) + 'h ago';
      var d = h / 24; if (d < 7) return Math.floor(d) + 'd ago';
      if (d < 30) return Math.floor(d / 7) + 'w ago';
      if (d < 365) return Math.floor(d / 30) + 'mo ago'; return Math.floor(d / 365) + 'y ago';
    }

    function card(d, matched) {
      if (!d) return ''; // defensive: a result whose data() didn't resolve is skipped, never crashes render
      var meta = d.meta || {}, f = d.filters || {};
      var matchHtml = '';
      if (matched && matched.length) {
        var shownM = matched.slice(0, 3), extraM = matched.length - shownM.length;
        matchHtml = '<span class="sf-match" title="Found via: ' + esc(matched.join(', ')) + '">' +
          '<span class="sf-match-lbl">Matched:</span>' +
          shownM.map(function (m) { return '<span class="sf-mtag">' + esc(m) + '</span>'; }).join('') +
          (extraM > 0 ? '<span class="sf-mtag sf-mtag-more">+' + extraM + ' more</span>' : '') + '</span>';
      }
      var title = meta.title || 'Untitled';
      var source = meta.source || (f.source && f.source[0]) || '';
      var typeRaw = meta.type || (f.type && f.type[0]) || '';
      var typeLabel = TYPE_LABEL[typeRaw] || typeRaw;
      var date = meta.date || '';
      var url = d.url;                 // our /article/ detail page (for "Read →")
      var pub = meta.link || url;      // publisher URL (image+title open this in a new tab, like the homepage card)
      var img = meta.image && meta.image.indexOf('/s2/favicons') === -1 ? meta.image : null;
      var grad = img ? '' : 'background:linear-gradient(135deg,#0ea5e933,#0ea5e910);';
      var imgPart = img
        ? '<img src="' + esc(img) + '" alt="" loading="lazy" referrerpolicy="no-referrer" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300">'
        : '';
      return '' +
      '<article class="group flex flex-col rounded-lg border border-slate-200 hover:border-sky-400 transition bg-white">' +
        '<a href="' + esc(pub) + '" target="_blank" rel="noopener noreferrer" class="block aspect-video bg-slate-100 overflow-hidden relative rounded-t-lg" style="' + grad + '">' +
          imgPart +
          '<div class="absolute inset-0 bg-white/10 pointer-events-none" style="backdrop-filter:blur(2.2px);-webkit-backdrop-filter:blur(2.2px);"></div>' +
          '<div class="absolute inset-0 flex items-center justify-center pointer-events-none">' +
            '<span class="text-white text-lg font-bold uppercase tracking-tight whitespace-nowrap max-w-[90%] truncate text-center px-2" style="text-shadow:0 2px 6px rgba(0,0,0,0.9);">' + esc(source || 'Maritime') + '</span>' +
          '</div>' +
        '</a>' +
        '<div class="flex-1 p-4 flex flex-col">' +
          '<div class="flex items-center gap-2 text-xs text-slate-500 mb-2 flex-wrap">' +
            (typeLabel ? '<span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-semibold uppercase tracking-wide bg-sky-50 text-sky-700">' + esc(typeLabel) + '</span>' : '') +
            (source ? '<span class="truncate">' + esc(source) + '</span>' : '') +
            (date ? '<span>·</span><time>' + esc(ago(date)) + '</time>' : '') +
          '</div>' +
          '<h3 class="font-semibold leading-snug mb-2 line-clamp-3 text-slate-900">' +
            '<a href="' + esc(pub) + '" target="_blank" rel="noopener noreferrer" class="group-hover:text-sky-600">' + esc(title) + '</a>' +
          '</h3>' +
          '<div class="mt-auto pt-3 border-t border-slate-100 flex items-center justify-between gap-2 text-xs text-slate-500">' +
            matchHtml +
            '<a href="' + esc(url) + '" class="hover:text-sky-600 shrink-0">Read →</a>' +
          '</div>' +
        '</div>' +
      '</article>';
    }

    // Semantic classes — styled in the <style> block (raised/pressable look,
    // fast 70ms transition, hover-lift, pressed-when-active). Kept out of Tailwind
    // utility strings so the JS-built buttons get full, instant styling.
    function chipClass(on) { return 'sf-chip' + (on ? ' on' : ''); }
    var chipEls = {}; // facet -> [{value, btn}]

    // GLOBAL sort toggle helpers. State mirrors sortPref: null = relevance (thumb
    // LEFT), 'date' = newest (thumb RIGHT). syncSortToggle() reflects the visual
    // state; showSortToggle(container, on) moves the single toggle element into the
    // right container (prepended) and shows/hides it.
    function syncSortToggle() {
      if (!sortWrap) return;
      var dateOn = sortPref === 'date';
      sortWrap.classList.toggle('is-date', dateOn);
      if (sortTrack) sortTrack.setAttribute('aria-checked', dateOn ? 'true' : 'false');
      if (sortRelLbl) sortRelLbl.classList.toggle('on', !dateOn);
      if (sortDateLbl) sortDateLbl.classList.toggle('on', dateOn);
    }
    // Move the single toggle element so it sits immediately BEFORE `beforeEl`
    // (e.g. just above the ungrouped grid, or just below the Best heading).
    function showSortToggle(beforeEl, on) {
      if (!sortWrap) return;
      if (!on) { sortWrap.classList.add('hidden'); return; }
      if (beforeEl && beforeEl.parentNode && sortWrap.nextSibling !== beforeEl) {
        beforeEl.parentNode.insertBefore(sortWrap, beforeEl);
      }
      sortWrap.classList.remove('hidden');
      syncSortToggle();
    }

    // Build the facet UI ONCE (init only). pf.filters() is ~2.4s on 51k — never
    // call it per-keystroke.
    function buildFacetsOnce(available) {
      facetsEl.innerHTML = '';
      chipEls = {};
      CHIP_FACETS.forEach(function (k) {
        var counts = available[k] || {};
        var entries = Object.keys(counts).map(function (v) { return [v, counts[v]]; });
        if (!entries.length) return;
        entries.sort(function (a, b) { return b[1] - a[1]; });
        var row = document.createElement('div');
        row.className = 'flex items-start gap-3';
        var lab = document.createElement('div');
        lab.className = 'text-xs font-bold uppercase tracking-wide text-slate-700 w-20 shrink-0 pt-1.5';
        lab.textContent = FACET_LABEL[k];
        var chips = document.createElement('div');
        chips.className = 'flex items-center flex-wrap gap-2 flex-1 min-w-0';
        chipEls[k] = [];
        entries.forEach(function (e) {
          var val = e[0], cnt = e[1];
          var b = document.createElement('button');
          b.className = chipClass(sel[k].has(val));
          var label = k === 'type' ? (TYPE_LABEL[val] || val) : val;
          b.innerHTML = esc(label) + (cnt ? ' <span class="cnt">' + cnt + '</span>' : '');
          b.addEventListener('click', function () {
            if (sel[k].has(val)) sel[k].delete(val); else sel[k].add(val);
            run();
          });
          chips.appendChild(b);
          chipEls[k].push({ value: val, btn: b });
        });
        row.appendChild(lab); row.appendChild(chips); facetsEl.appendChild(row);
      });
      // source — grouped multi-select checkbox list
      sourceCounts = available.source || {};
      renderSourceList('');
      updateChipStates();
    }

    // Build the grouped checkbox list (filtered by `q`). Mirrors v1's grouping.
    function renderSourceList(q) {
      if (!sourceList) return;
      q = (q || '').toLowerCase();
      var grouped = { news: [], pi: [], psc: [], magazines: [], youtube: [], others: [] };
      Object.keys(sourceCounts).forEach(function (name) {
        if (q && name.toLowerCase().indexOf(q) === -1) return;
        grouped[srcGroupOf(name)].push(name);
      });
      var html = '';
      SRC_GROUP_ORDER.forEach(function (g) {
        var list = grouped[g];
        if (!list.length) return;
        list.sort(function (a, b) { return a.localeCompare(b); });
        html += '<div class="text-[10px] font-bold uppercase tracking-wide text-slate-400 mt-2 mb-1 px-1">' + esc(SRC_GROUP_LABELS[g]) + '</div>';
        list.forEach(function (name) {
          html += '<label class="flex items-center gap-2 text-sm py-0.5 px-1 rounded hover:bg-slate-50 cursor-pointer">' +
            '<input type="checkbox" class="accent-sky-600" data-src="' + esc(name) + '"' + (sel.source.has(name) ? ' checked' : '') + '>' +
            '<span class="truncate">' + esc(name) + ' <span class="text-slate-400">(' + (sourceCounts[name] || 0) + ')</span></span></label>';
        });
      });
      if (!html) html = '<p class="text-xs text-slate-500 py-2 text-center">No sources match.</p>';
      sourceList.innerHTML = html;
      Array.prototype.forEach.call(sourceList.querySelectorAll('input[data-src]'), function (cb) {
        cb.addEventListener('change', function () {
          var name = cb.getAttribute('data-src');
          if (cb.checked) sel.source.add(name); else sel.source.delete(name);
          updateChipStates();
          run();
        });
      });
    }

    function updateChipStates() {
      CHIP_FACETS.forEach(function (k) {
        (chipEls[k] || []).forEach(function (c) {
          c.btn.className = chipClass(sel[k].has(c.value));
        });
      });
      if (sourceBtn) {
        var n = sel.source.size;
        sourceBtn.textContent = (n === 0 ? 'All sources' : n === 1 ? Array.from(sel.source)[0] : n + ' sources') + ' ▾';
        sourceBtn.className = chipClass(n > 0);
      }
    }

    // Selected filters as removable pills (each with ×) under the facets.
    function renderActiveChips() {
      if (!chipsEl) return;
      function pill(label, k, val) {
        return '<span class="sf-pill">' + esc(label) +
          '<button data-k="' + esc(k) + '" data-v="' + esc(val) + '" class="sf-pill-x" aria-label="remove">×</button></span>';
      }
      var html = '';
      // NOTE: the query is shown (with its count + ×) in #sf-terms (renderActiveTerms),
      // not here — avoids the duplicate query pill. #sf-chips = facet/source pills only.
      CHIP_FACETS.forEach(function (k) {
        sel[k].forEach(function (v) { html += pill(k === 'type' ? (TYPE_LABEL[v] || v) : v, k, v); });
      });
      sel.source.forEach(function (v) { html += pill(v, 'source', v); });
      chipsEl.innerHTML = html;
      Array.prototype.forEach.call(chipsEl.querySelectorAll('button[data-k]'), function (b) {
        b.addEventListener('click', function () {
          var k = b.getAttribute('data-k'), v = b.getAttribute('data-v');
          if (k === 'q') { sel.q = ''; qEl.value = ''; } else sel[k].delete(v);
          run();
        });
      });
    }

    // ---- Result consumption: k-way merge across the per-term streams ----------
    // Each stream (one per search term) is already date-sorted DESC by Pagefind.
    // We merge them into ONE globally date-sorted stream (pure date order, per the
    // user's choice 2026-06-10), resolving each result's data() LAZILY — only the
    // heads being compared + the items actually output — so a broad expansion term
    // never forces thousands of fragment fetches. Dedup by url (handles base/delta
    // AND cross-term overlap). A slow/failing fragment is skipped, never hangs.
    function withTimeout(p, ms) {
      return new Promise(function (resolve) {
        var done = false;
        var t = setTimeout(function () { if (!done) { done = true; resolve(); } }, ms);
        p.then(function (v) { if (!done) { done = true; clearTimeout(t); resolve(v); } },
               function () { if (!done) { done = true; clearTimeout(t); resolve(); } });
      });
    }
    function resolveHeads(streams) {
      var jobs = [];
      streams.forEach(function (s) {
        var r = s.results[s.idx];
        if (r && !r.__data && typeof r.data === 'function') {
          jobs.push(withTimeout(r.data().then(function (d) { r.__data = d; }), 8000));
        }
      });
      return jobs.length ? Promise.all(jobs) : Promise.resolve();
    }
    function dateOf(r) {
      var d = r && r.__data && r.__data.meta ? r.__data.meta.date : null;
      var t = d ? new Date(d).getTime() : NaN;
      return isNaN(t) ? -Infinity : t; // undated sinks to the bottom
    }
    // A "group" = { tiers:[ [{results,idx}], ... ], byDate, seen:{}, excludeIds:{} }.
    // tiers are consumed IN ORDER: a tier is fully drained before the next begins
    // (so Best = [ [raw exact phrase], [chip phrases] ] surfaces the exact query first).
    // Within a tier: byDate=true → date k-way merge; byDate=false → relevance order.
    // pullGroup returns at most `n` de-duplicated results (DOM pagination = PAGE).
    function tierActive(tier) { return tier.some(function (s) { return s.idx < s.results.length; }); }
    function groupHasMore(g) { return !!g && g.tiers.some(tierActive); }
    async function pullGroup(g, n) {
      var out = [];
      while (out.length < n) {
        var tier = null;
        for (var ti = 0; ti < g.tiers.length; ti++) { if (tierActive(g.tiers[ti])) { tier = g.tiers[ti]; break; } }
        if (!tier) break; // all tiers exhausted
        await resolveHeads(tier);
        var pick = -1, bestT = 0;
        for (var i = 0; i < tier.length; i++) {
          var r = tier[i].results[tier[i].idx];
          if (!r) continue;
          if (!g.byDate) { pick = i; break; } // relevance: first stream with items, in order
          var t = dateOf(r);
          if (pick === -1 || t > bestT) { pick = i; bestT = t; }
        }
        if (pick === -1) break;
        var s = tier[pick];
        var chosen = s.results[s.idx];
        s.idx++; // advance even on a skip, so progress is guaranteed
        if (g.excludeIds && chosen.id && g.excludeIds[chosen.id]) continue; // already in Best
        var u = chosen.__data && chosen.__data.url;
        if (u) { if (g.seen[u]) continue; g.seen[u] = 1; }
        out.push(chosen);
      }
      return out;
    }
    // `tok` ties this render to the search run that started it (run()'s token, or the
    // token captured at load-more click time). pullGroup awaits data() (network on
    // cold cdn), so a NEWER search can fire — bumping `pending` and clearing the
    // containers — WHILE this render is still in-flight. Without the guard, this
    // superseded render would insertAdjacentHTML its now-stale cards into the freshly
    // cleared container → count(new) ≠ cards, plus leftover cards from the old query
    // (the consecutive-search duplication/false-match bug, measured 2026-06-11).
    // Re-check `pending === tok` AFTER the await, immediately before the DOM append.
    async function renderGroup(g, containerEl, moreBtn, tok) {
      if (!g) return 0;
      var batch = await pullGroup(g, PAGE);   // only PAGE cards reach the DOM per call
      if (tok !== undefined && pending !== tok) return 0; // superseded by a newer search → drop this append
      var html = '';
      for (var i = 0; i < batch.length; i++) html += card(batch[i].__data, matchedFor(batch[i].id));
      containerEl.insertAdjacentHTML('beforeend', html);
      if (moreBtn) moreBtn.classList.toggle('hidden', !groupHasMore(g)); // hide if nothing left
      return batch.length;
    }
    // Related-terms checkbox panel for the matched key. All ON by default; toggling
    // a checkbox updates relSel + re-runs. Rebuilt only when the key changes (so the
    // DOM checkbox state + open/closed state persist while the user keeps typing).
    // Reuses the source-dropdown's safelisted classes (JS-built → not Tailwind-scanned).
    function updateRelatedBtn() {
      if (relatedBtn) relatedBtn.textContent = 'Related terms (' + relSel.size + ') ▾';
    }
    // Fill the per-chip result counts from ACTIVE (set after the searches run). Counts
    // are available for searched (selected) terms; unchecked chips show no number.
    function updateChipCounts() {
      if (!relatedList) return;
      Array.prototype.forEach.call(relatedList.querySelectorAll('.sf-chip-cnt'), function (el) {
        var c = activeCount(el.getAttribute('data-cnt'));
        el.textContent = c ? (c.toLocaleString('en-US')) : '';
      });
    }
    // Active search-term pills beside the count: the raw query + selected chips, each
    // with its result count and an × to drop it (unchecks the chip / clears the query).
    function renderActiveTerms() {
      if (!termsEl) return;
      var items = [];
      var seenLbl = {};
      function normLbl(s) { return s.replace(/^"|"$/g, '').trim().toLowerCase(); }
      if (sel.q) { items.push({ label: sel.q, kind: 'q', countKey: foldTr(sel.q.replace(/^"|"$/g, '')) }); seenLbl[normLbl(sel.q)] = true; }
      if (relKey) relSel.forEach(function (t) { if (seenLbl[normLbl(t)]) return; seenLbl[normLbl(t)] = true; items.push({ label: t, kind: 'chip' }); });
      if (!items.length) { termsEl.innerHTML = ''; termsEl.classList.add('hidden'); termsEl.classList.remove('flex'); return; }
      termsEl.innerHTML = items.map(function (it) {
        var c = activeCount(it.countKey || it.label);
        return '<span class="sf-term">' + esc(it.label) + (c ? ' <span class="sf-term-cnt">' + c.toLocaleString('en-US') + '</span>' : '') +
          '<button type="button" class="sf-term-x" data-term="' + esc(it.label) + '" data-kind="' + it.kind + '" aria-label="remove">×</button></span>';
      }).join('');
      termsEl.classList.remove('hidden'); termsEl.classList.add('flex');
      Array.prototype.forEach.call(termsEl.querySelectorAll('.sf-term-x'), function (btn) {
        btn.addEventListener('click', function () {
          var t = btn.getAttribute('data-term');
          if (btn.getAttribute('data-kind') === 'q') { sel.q = ''; qEl.value = ''; syncQClear(); }
          else {
            relSel.delete(t); updateRelatedBtn();
            if (relatedList) Array.prototype.forEach.call(relatedList.querySelectorAll('input[data-rel]'), function (cb) { if (cb.getAttribute('data-rel') === t) cb.checked = false; });
          }
          run();
        });
      });
    }
    function renderRelatedPanel(rel) {
      if (!relatedWrap) return;
      if (!rel) {
        relatedWrap.classList.add('hidden');
        if (relatedPanel) relatedPanel.classList.add('hidden');
        if (relatedList) relatedList.innerHTML = '';
        return;
      }
      relatedWrap.classList.remove('hidden');
      if (relatedTitle) relatedTitle.textContent = 'Related to “' + rel.title + '”';
      var html = '';
      rel.terms.forEach(function (term) {
        html += '<label class="flex items-center gap-2 text-sm py-0.5 px-1 rounded hover:bg-slate-50 cursor-pointer">' +
          '<input type="checkbox" class="accent-sky-600" data-rel="' + esc(term) + '"' + (relSel.has(term) ? ' checked' : '') + '>' +
          '<span class="truncate">' + esc(term) + '</span>' +
          '<span class="sf-chip-cnt" data-cnt="' + esc(term) + '"></span></label>';
      });
      relatedList.innerHTML = html;
      Array.prototype.forEach.call(relatedList.querySelectorAll('input[data-rel]'), function (cb) {
        cb.addEventListener('change', function () {
          var term = cb.getAttribute('data-rel');
          if (cb.checked) relSel.add(term); else relSel.delete(term);
          updateRelatedBtn();
          run();
        });
      });
      updateRelatedBtn();
    }

    async function run() {
      if (!pf) return;
      writeURL();
      updateChipStates();
      renderActiveChips();
      var active = isActive();
      var staticFeed = document.getElementById('static-feed');
      if (staticFeed) staticFeed.hidden = active;
      resultsWrap.classList.toggle('hidden', !active);
      activeEl.classList.toggle('hidden', !active);
      activeEl.classList.toggle('flex', active);
      function clearResults() {
        resultsEl.innerHTML = ''; resultsEl.classList.add('hidden'); if (moreBtn) moreBtn.classList.add('hidden');
        if (bestEl) bestEl.innerHTML = ''; if (broaderEl) broaderEl.innerHTML = '';
        if (bestWrap) bestWrap.classList.add('hidden'); if (broaderWrap) broaderWrap.classList.add('hidden');
        if (bestMore) bestMore.classList.add('hidden'); if (broaderMore) broaderMore.classList.add('hidden');
      }
      if (!active) {
        clearResults(); curSingle = curBest = curBroader = null; relKey = null; relSel = new Set();
        renderRelatedPanel(null); showSortToggle(null, false); if (loadEl) loadEl.classList.add('hidden');
        return;
      }

      // Loading state IMMEDIATELY (cold cdn index load ~9.5s first time, ~1.6s warm).
      clearResults();
      emptyEl.classList.add('hidden');
      if (loadEl) loadEl.classList.remove('hidden');
      var token = {}; pending = token;

      // Related-terms dropdown: prefix-match the typed text to a synonym key.
      // Rebuild + AUTO-OPEN only when the matched key changes (so the user's
      // checkbox toggles + open/closed state persist while they keep typing).
      // A new key starts with ALL related terms checked; only checked terms join
      // the search (live — user 2026-06-10). Multi-word ones search as phrases.
      var rel = relatedFor(sel.q);
      var key = rel ? rel.title : null;
      if (key !== relKey) {
        relKey = key;
        relSel = rel ? new Set(rel.terms) : new Set();
        renderRelatedPanel(rel);
        if (rel && relatedPanel) relatedPanel.classList.remove('hidden'); // auto-open on a new match
      }
      // ---- Term sets: strong = multi-word phrases (Best); broad = words/AND (Broader base) ----
      var raw = foldTr(sel.q);   // search-side query: TR letters → ASCII (display keeps sel.q)
      var quoted = isQuoted(raw);
      var multiWord = !!raw && /\s/.test(raw.trim());
      function isPhrase(t) { return /\s/.test(t); }
      function addU(arr, t) { if (t && arr.indexOf(t) === -1) arr.push(t); }
      // termForm: multi-word terms always search as exact phrases; on a SPELLING/VARIANT
      // topic (rel.exact) single-token terms are ALSO searched quoted = EXACT match — this
      // catches author-side joined-typos (e.g. "hatchcover" → 5 real articles, "cargohold"
      // → 1) while killing Pagefind's prefix/stem NOISE for forms nobody writes
      // ("hatchcoaming"/"mainengine" → 0). MEASURED 2026-06-11. Quoting a real single word
      // (lifeboat/crankshaft) returns the same count, so it is always safe here.
      function termForm(t) { return (isPhrase(t) || (rel && rel.exact)) ? '"' + t + '"' : t; }
      var strong = [], broad = [], singleTerms = [];
      if (!quoted) {
        if (multiWord) {
          // MULTI-WORD → grouped. Best = exact phrase + multi-word seeds + selected chips; Broader = raw AND.
          if (raw) { addU(strong, '"' + raw + '"'); addU(broad, raw); }
          if (rel) {
            (rel.seeds || []).forEach(function (t) { if (isPhrase(t)) addU(strong, '"' + t + '"'); });
            rel.terms.forEach(function (t) { if (relSel.has(t)) addU(strong, termForm(t)); });
          }
        } else if (raw) {
          // SINGLE WORD → ONE merged list, NO Best/Broader split (a single word can't
          // "scatter", so the split only confuses — user 2026-06-11, the "grain" case).
          // List = raw word + topic trigger forms + selected chips; chips still apply.
          addU(singleTerms, (rel && rel.exact) ? '"' + raw + '"' : raw);
          if (rel) {
            (rel.seeds || []).forEach(function (t) { addU(singleTerms, termForm(t)); });
            rel.terms.forEach(function (t) { if (relSel.has(t)) addU(singleTerms, termForm(t)); });
          }
        }
      }
      var filt = filtersObj();
      resetActive();

      try {
        // ===== QUOTED phrase, BROWSE, or SINGLE-WORD → one ungrouped list (no headings) =====
        if (quoted || !multiWord) {
          var single = quoted ? [raw] : singleTerms;
          // relevance is a meaningful choice ONLY when there's EXACTLY ONE search
          // stream (a lone word OR a quoted phrase). length===0 = pure facet/browse
          // (source/type/segment/theme selected with no text query) → relevance is
          // meaningless (no query term to rank by) → date-only, no toggle (user
          // 2026-06-12). length>1 = a topic's merged chip streams → no comparable
          // relevance order → also date-merged.
          var singleStream = single.length === 1;
          var useRel = singleStream && sortPref !== 'date';
          var sOpts = { filters: filt }; if (!useRel) sOpts.sort = { date: 'desc' };
          var sterms = single.length ? single : [null];
          var sres = await Promise.all(sterms.map(function (t) { return pf.search(t, sOpts); }));
          if (pending !== token) return;
          sres.forEach(function (s, i) { addActive(sterms[i], s.results); });
          updateChipCounts(); renderActiveTerms();
          curSingle = { tiers: [ sres.map(function (s) { return { results: s.results, idx: 0 }; }) ], byDate: !useRel, seen: {} };
          curBest = curBroader = null;
          var ids = {}; sres.forEach(function (s) { for (var i = 0; i < s.results.length; i++) ids[s.results[i].id] = 1; });
          var stotal = Object.keys(ids).length;
          countEl.textContent = stotal.toLocaleString('en-US') + ' result' + (stotal === 1 ? '' : 's');
          // GLOBAL toggle at the TOP of the ungrouped list (no "Best matches" heading
          // here) — placed just above the grid. Shown ONLY when the list is a SINGLE
          // stream (lone word / quoted phrase), where relevance is a real, different
          // order. A single word that expands to a topic (multiple merged chip streams)
          // is date-merged with no comparable relevance, so the toggle would be inert →
          // hide it there to avoid a control that does nothing (user 2026-06-12).
          showSortToggle(resultsEl, singleStream && stotal > 0);
          resultsEl.classList.remove('hidden');
          try { await renderGroup(curSingle, resultsEl, moreBtn, token); } catch (e) {}
          if (pending !== token) return;
          if (loadEl) loadEl.classList.add('hidden');
          emptyEl.classList.toggle('hidden', stotal > 0);
          return;
        }

        // ===== GROUPED: Best (exact phrase FIRST, then chips) + Broader (broad − Best) =====
        var rawPhrase = (multiWord && !quoted) ? '"' + raw + '"' : null;          // the user's typed phrase
        var secondary = strong.filter(function (t) { return t !== rawPhrase; });  // seed + chip phrases
        // Best now HONORS the global toggle: newest → force date sort; relevance →
        // let Pagefind relevance order apply (no sort key) and merge by relevance.
        var bestByDate = sortPref === 'date';
        var bOpts = { filters: filt }; if (bestByDate) bOpts.sort = { date: 'desc' };
        var bestIds = {};
        function toStream(s) { for (var i = 0; i < s.results.length; i++) bestIds[s.results[i].id] = 1; return { results: s.results, idx: 0 }; }
        var bestTiers = [];
        if (rawPhrase) { var pr = await pf.search(rawPhrase, bOpts); if (pending !== token) return; bestTiers.push([toStream(pr)]); addActive(rawPhrase, pr.results); } // tier 0: exact phrase
        var secSearches = await Promise.all(secondary.map(function (t) { return pf.search(t, bOpts); }));
        if (pending !== token) return;
        secSearches.forEach(function (s, i) { addActive(secondary[i], s.results); });
        if (secSearches.length) bestTiers.push(secSearches.map(toStream));         // tier 1: chip phrases
        var useRel2 = sortPref !== 'date';            // Broader: relevance default, Newest on demand
        var brByDate = !useRel2 || broad.length > 1;  // multiple broad streams → date (relevance not comparable)
        var brOpts = { filters: filt }; if (brByDate) brOpts.sort = { date: 'desc' };
        var bterms = broad.length ? broad : [raw];
        var brSearches = await Promise.all(bterms.map(function (t) { return pf.search(t, brOpts); }));
        if (pending !== token) return;
        brSearches.forEach(function (s, i) { addActive(bterms[i], s.results); });
        updateChipCounts(); renderActiveTerms();

        // Newest ("date") mode: COLLAPSE the Best tiers into ONE flat tier so the
        // date k-way merge runs across exact-phrase + chip results together — otherwise
        // tiers drain in order and the (possibly old) exact-phrase match stays pinned on
        // top even though the user asked for newest-first (the "grain cargo" → 8-month-old
        // BIMCO Grain Code on top bug, user 2026-06-12). Relevance mode keeps the tiered
        // order (exact phrase first, then chips).
        var bestTierList = bestByDate
          ? [bestTiers.reduce(function (acc, t) { return acc.concat(t); }, [])]
          : bestTiers;
        curBest = { tiers: bestTierList, byDate: bestByDate, seen: {} };
        curBroader = { tiers: [ brSearches.map(function (s) { return { results: s.results, idx: 0 }; }) ], byDate: brByDate, seen: {}, excludeIds: bestIds };
        curSingle = null;

        var bestCount = Object.keys(bestIds).length;
        var brIds = {}; brSearches.forEach(function (s) { for (var i = 0; i < s.results.length; i++) { var id = s.results[i].id; if (!bestIds[id]) brIds[id] = 1; } });
        var brCount = Object.keys(brIds).length;
        var total = bestCount + brCount;
        countEl.textContent = total.toLocaleString('en-US') + ' result' + (total === 1 ? '' : 's');

        // GLOBAL toggle, placed directly below the "Best matches" heading (just above
        // the Best grid) when Best has results; otherwise above the Broader grid (so
        // it is never trapped inside the hidden #sf-best-wrap). Shown ONLY when Broader
        // has results — Broader is the genuinely re-orderable group; when there is only
        // Best (merged phrase tiers, relevance order is flat) the toggle would be inert,
        // so hide it (user 2026-06-12).
        showSortToggle(bestCount > 0 ? bestEl : broaderEl, brCount > 0);

        if (bestCount > 0) { bestWrap.classList.remove('hidden'); try { await renderGroup(curBest, bestEl, bestMore, token); } catch (e) {} }
        if (pending !== token) return;
        if (brCount > 0) { broaderWrap.classList.remove('hidden'); try { await renderGroup(curBroader, broaderEl, broaderMore, token); } catch (e) {} }
        if (pending !== token) return;

        if (loadEl) loadEl.classList.add('hidden');
        emptyEl.classList.toggle('hidden', total > 0);
      } catch (e) { if (loadEl) loadEl.classList.add('hidden'); }
    }

    // Load-more: capture the live search token now; if a new search supersedes this
    // group mid-fetch (pending bumped + containers cleared), renderGroup drops the append.
    moreBtn.addEventListener('click', async function () { var tok = pending; await renderGroup(curSingle, resultsEl, moreBtn, tok); });
    if (bestMore) bestMore.addEventListener('click', async function () { var tok = pending; await renderGroup(curBest, bestEl, bestMore, tok); });
    if (broaderMore) broaderMore.addEventListener('click', async function () { var tok = pending; await renderGroup(curBroader, broaderEl, broaderMore, tok); });
    // GLOBAL sort toggle: clicking the track flips; clicking a label selects that
    // side. Drives sortPref for the WHOLE result set (Best + Broader + single list).
    function setSort(pref) { if (sortPref !== pref) { sortPref = pref; syncSortToggle(); run(); } }
    if (sortTrack) sortTrack.addEventListener('click', function () { setSort(sortPref === 'date' ? null : 'date'); });
    if (sortRelLbl) sortRelLbl.addEventListener('click', function () { setSort(null); });
    if (sortDateLbl) sortDateLbl.addEventListener('click', function () { setSort('date'); });
    clearBtn.addEventListener('click', function () {
      sel.q = ''; qEl.value = ''; ALL_FACETS.forEach(function (k) { sel[k] = new Set(); }); syncQClear(); run();
    });
    if (qClear) qClear.addEventListener('click', function () {
      sel.q = ''; qEl.value = ''; syncQClear(); qEl.focus(); run();
    });
    qEl.addEventListener('input', function () {
      sel.q = qEl.value.trim();
      sortPref = null; // a new/edited query defaults back to Relevance
      syncQClear();
      clearTimeout(debounce);
      // Short queries match a huge slice of the 51k index — heavy + useless, and
      // 1-2 chars froze a slower machine (2026-06-08). Require 3+ chars; 0 (cleared)
      // still runs to reset back to the static feed. EXCEPTION: a 2-char query that
      // is a known synonym-map key (GA, CP, BV, LR, NK) is allowed — its expansion
      // gives real results.
      if (sel.q.length > 0 && sel.q.length < 3 && !isShortExactTrigger(sel.q)) return;
      debounce = setTimeout(run, 300);
    });
    // Source panel: toggle open, re-render with current selection on open, filter
    // as you type, close on outside-click. Checkbox changes are wired in
    // renderSourceList (each toggles sel.source + run()).
    if (sourceBtn) sourceBtn.addEventListener('click', function (e) {
      e.stopPropagation();
      var open = sourcePanel.classList.contains('hidden');
      if (open) { renderSourceList(sourceQ ? sourceQ.value : ''); sourcePanel.classList.remove('hidden'); if (sourceQ) sourceQ.focus(); }
      else sourcePanel.classList.add('hidden');
    });
    if (sourceQ) sourceQ.addEventListener('input', function () { renderSourceList(sourceQ.value); });
    if (sourcePanel) sourcePanel.addEventListener('click', function (e) { e.stopPropagation(); });
    // Related-terms dropdown: button toggles it; clicks inside don't close it.
    if (relatedBtn) relatedBtn.addEventListener('click', function (e) { e.stopPropagation(); if (relatedPanel) relatedPanel.classList.toggle('hidden'); });
    if (relatedPanel) relatedPanel.addEventListener('click', function (e) { e.stopPropagation(); });
    document.addEventListener('click', function () {
      if (sourcePanel) sourcePanel.classList.add('hidden');
      if (relatedPanel) relatedPanel.classList.add('hidden');
    });
    window.addEventListener('popstate', function () { readURL(); run(); });

    async function init() {
      // Load the maritime search map (separate static JSON, not inlined). If it's
      // missing/unreachable, search still works — just no related-term chips.
      // no-cache so Phase B map edits show up without an edge-cache purge.
      try {
        var _mr = await fetch((base || '') + '/maritime-search-map.json', { cache: 'no-cache' });
        if (_mr.ok) buildMapIndex(await _mr.json());
      } catch (e) { /* map unavailable — chips disabled, search unaffected */ }
      try {
        pf = await import((base || '') + '/_pagefind/pagefind.js');
        await pf.options({ baseUrl: '/' });
        await pf.init();
        // Merge the DELTA index (recent ~2 weeks, rebuilt every 3h) on top of the
        // static BASE index (full archive, rebuilt weekly) → search stays ~3h-fresh
        // without re-reading all 51k rows from Nano. baseUrl:'/' so delta result
        // URLs resolve to the real /article/<id>/ detail pages, not /_pagefind-delta/…
        // (measured 2026-06-08). Wrapped: if the delta isn't deployed yet, base-only
        // search still works. Overlap with base is deduped at render (by result.url).
        try { await pf.mergeIndex((base || '') + '/_pagefind-delta', { baseUrl: '/' }); }
        catch (e) { /* delta not deployed yet — base-only search is fine */ }
        var avail = await pf.filters(); // ONE call (post-merge) — builds the facet UI
        buildFacetsOnce(avail);
        readURL();
        syncQClear();
        updateChipStates();
        if (isActive()) run();
        // NOTE: no eager "warming" search here. A throwaway filter search on load
        // ran the heaviest Pagefind op (18k-result filter) concurrently with the
        // user's first keystrokes → on a slower machine/connection the tab went
        // "not responding" (reported 2026-06-08, appeared right after warming was
        // added). The first filter is slower without it (cold cdn index ≈ network,
        // async, not a freeze — the "Searching…" state covers it). Don't re-add.
      } catch (e) { /* index not built yet (dev) — static feed stays visible */ }
    }
    if ('requestIdleCallback' in window) requestIdleCallback(init, { timeout: 2000 });
    else setTimeout(init, 1);
  })();
</script>

<style is:global>
  /* NOTE: is:global (NOT scoped) is REQUIRED — the chips/pills/source buttons are
     created in JS (createElement / innerHTML) so they never get Astro's scope
     attribute; a scoped selector (.sf-chip[data-astro-cid]) would not match them.
     Class names are unique to this component, so global is safe. */

  /* Hide the browser's native type=search clear ×; we render our own (#sf-q-clear)
     pinned to the input edge — the UA pseudo-element can't be repositioned. */
  #sf-q::-webkit-search-cancel-button { -webkit-appearance: none; appearance: none; }
  #sf-q::-webkit-search-decoration { -webkit-appearance: none; appearance: none; }

  /* Sonar-ping loading animation (CSS-only, maritime theme, sky palette).
     3 staggered expanding rings + a solid center dot. When #sf-loading gets the
     `hidden` class (display:none) the whole subtree — animation included — is
     removed, so it disappears cleanly and burns no CPU while idle. */
  .sf-sonar {
    position: relative;
    width: 72px;
    height: 72px;
    margin: 0 auto;
  }
  .sf-sonar::after {
    content: '';
    position: absolute;
    inset: 44%;
    background: #0284c7; /* sky-600 */
    border-radius: 9999px;
  }
  .sf-sonar span {
    position: absolute;
    inset: 0;
    border: 2px solid #0ea5e9; /* sky-500 */
