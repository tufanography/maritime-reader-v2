---
// Search dispatcher. DEFAULT (flag unset) → the proven PagefindUI widget
// (WidgetSearch), byte-identical to before. PUBLIC_HYBRID_SEARCH=1 → the
// Phase-1 hybrid search (keyword + synonym expansion via the Pagefind JS API,
// OR-merge). Flag-gated so the live search UX is unchanged until you flip it.
import WidgetSearch from './WidgetSearch.astro';
import HybridSearch from './HybridSearch.astro';
const hybrid = import.meta.env.PUBLIC_HYBRID_SEARCH === '1';
---
{hybrid ? <HybridSearch /> : <WidgetSearch />}
