---
// Pagefind static client-side search. The index lives at /_pagefind/
// and is generated by the postbuild step (npm run build → astro build →
// pagefind --site dist). All search happens in the browser against the
// static index — no API, no server, no AI.
//
// HANDOFF §3: zero runtime AI; HANDOFF §5 L5: "client-side search →
// prebuilt static index (Pagefind), no server."
//
// R2-feasibility proof (2026-06-01): PUBLIC_PAGEFIND_BASE lets us serve the
// Pagefind data layer (pagefind-ui.js + core + wasm + index + fragments) from
// a different origin (Cloudflare R2) instead of same-origin /_pagefind/. When
// the env var is UNSET, behaviour is byte-identical to before (same-origin,
// no bundlePath). When set (e.g. https://<bucket>.r2.dev), the UI + index load
// cross-origin — this is what we measure for the "search still fast?" gate.
const base = (import.meta.env.PUBLIC_PAGEFIND_BASE ?? '').replace(/\/$/, '');
---
<link rel="stylesheet" href={`${base}/_pagefind/pagefind-ui.css`} />
<div id="search" style="margin: 6px 0 14px;"></div>
<script is:inline define:vars={{ base }}>
  (function () {
    function init() {
      if (!window.PagefindUI) return;
      new window.PagefindUI({
        element: '#search',
        bundlePath: base ? base + '/_pagefind/' : undefined,
        // baseUrl '/' is REQUIRED when bundlePath is cross-origin (the index is
        // served from cdn.maritimereader.com, an R2-direct custom domain).
        // Without it, Pagefind infers the SITE root from bundlePath's origin and
        // emits ABSOLUTE result links like https://cdn.maritimereader.com/article/<id>/.
        // cdn is bound straight to R2 (no Worker) so it can't resolve /article/<id>/
        // -> /article/<id>/index.html, and every search-result click 404'd with the
        // raw R2 "Is this your bucket" page (proven 2026-06-06, Playwright). With
        // baseUrl '/', links are root-relative (/article/<id>/) and resolve against
        // the PAGE origin (the Worker on apex/www/v2), which serves the HTML. 200.
        baseUrl: '/',
        showSubResults: true,
        showImages: false,
        resetStyles: false,
        translations: { placeholder: 'Search maritime news…' },
      });
    }
    var s = document.createElement('script');
    s.src = (base || '') + '/_pagefind/pagefind-ui.js';
    s.onload = init;
    s.onerror = function () {
      // Index not built yet (e.g. `astro dev` without `npm run build` first).
      // Hide the search box rather than throwing a visible error.
      var el = document.getElementById('search');
      if (el) el.style.display = 'none';
    };
    document.head.appendChild(s);

    // Preload Pagefind's wasm + index metadata during page-load idle, so the
    // FIRST search only fetches result fragments instead of the full cold chain
    // (core + wasm + meta + index). MEASURED 2026-06-03 against the live 49.5k
    // index on R2 (cdn.maritimereader.com) from Turkey: cold first-search drops
    // from ~1089ms (over the 1s target) to ~766ms (under it). init() warms the
    // heavy fixed cost (~233ms, well before a user types); the query's own index
    // chunk + fragments still load at search time. Best-effort — a failure
    // (e.g. index not built yet in dev) is swallowed; lazy search still works.
    function preloadPagefind() {
      import((base || '') + '/_pagefind/pagefind.js')
        .then(function (pf) { return pf && pf.init && pf.init(); })
        .catch(function () {});
    }
    if ('requestIdleCallback' in window) requestIdleCallback(preloadPagefind, { timeout: 3000 });
    else setTimeout(preloadPagefind, 1);
  })();
</script>
