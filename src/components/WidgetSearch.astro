---
// The proven PagefindUI widget — DEFAULT search. Extracted verbatim from the
// original Search.astro so it can sit at template top-level (an is:inline script
// can't be wrapped in a JSX ternary expression). Search.astro now dispatches to
// this or to HybridSearch based on PUBLIC_HYBRID_SEARCH.
//
// Pagefind static client-side search. The index lives at /_pagefind/ and is
// generated by the postbuild step (pagefind --site dist). All search happens in
// the browser against the static index — no API, no server, no AI.
//
// PUBLIC_PAGEFIND_BASE lets us serve the Pagefind data layer from a different
// origin (Cloudflare R2). Unset → same-origin /_pagefind/ (byte-identical to
// before). Set (e.g. https://cdn.maritimereader.com) → cross-origin load.
const base = (import.meta.env.PUBLIC_PAGEFIND_BASE ?? '').replace(/\/$/, '');
---
<link rel="stylesheet" href={`${base}/_pagefind/pagefind-ui.css`} />
<div id="search" style="margin: 6px 0 14px;"></div>
<script is:inline define:vars={{ base }}>
  (function () {
    function init() {
      if (!window.PagefindUI) return;
      new window.PagefindUI({
        element: '#search',
        bundlePath: base ? base + '/_pagefind/' : undefined,
        // baseUrl '/' is REQUIRED when bundlePath is cross-origin (the index is
        // served from cdn.maritimereader.com, an R2-direct custom domain).
        // Without it, Pagefind infers the SITE root from bundlePath's origin and
        // emits ABSOLUTE result links like https://cdn.maritimereader.com/article/<id>/.
        // cdn is bound straight to R2 (no Worker) so it can't resolve /article/<id>/
        // -> /article/<id>/index.html, and every search-result click 404'd. With
        // baseUrl '/', links are root-relative (/article/<id>/) and resolve against
        // the PAGE origin (the Worker on apex/www/v2), which serves the HTML. 200.
        baseUrl: '/',
        showSubResults: true,
        showImages: false,
        resetStyles: false,
        translations: { placeholder: 'Search maritime news…' },
      });
    }
    var s = document.createElement('script');
    s.src = (base || '') + '/_pagefind/pagefind-ui.js';
    s.onload = init;
    s.onerror = function () {
      // Index not built yet (e.g. astro dev without npm run build first).
      // Hide the search box rather than throwing a visible error.
      var el = document.getElementById('search');
      if (el) el.style.display = 'none';
    };
    document.head.appendChild(s);

    // Preload Pagefind wasm + index metadata during idle so the FIRST search
    // only fetches result fragments instead of the full cold chain.
    function preloadPagefind() {
      import((base || '') + '/_pagefind/pagefind.js')
        .then(function (pf) { return pf && pf.init && pf.init(); })
        .catch(function () {});
    }
    if ('requestIdleCallback' in window) requestIdleCallback(preloadPagefind, { timeout: 3000 });
    else setTimeout(preloadPagefind, 1);
  })();
</script>
