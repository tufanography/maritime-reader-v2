---
// Newsletter sidebar — slice 2 of the v2 frontend port (2026-05-31).
// Mirrors v1's components/NewsletterSidebar.tsx layout. Static for now
// (no modal, no useState); the email submit POSTs to a Cloudflare
// Worker endpoint that lives in HANDOFF §5 layer 5 — that worker is
// part of a later slice. For slice 2 the form action is a placeholder
// (`/newsletter/subscribe`) that doesn't exist yet and will return a
// 404 if clicked; this is the dürüst placeholder option (no fake
// success screen, no hidden state). Slice 3 will either point this at
// the real worker URL or wire the modal back as a React island.
---
<div class="rounded-lg border border-sky-200 bg-gradient-to-br from-sky-50 via-white to-cyan-50 p-5">
  <div class="inline-flex items-center gap-2 px-2.5 py-1 rounded-full bg-sky-600 text-white text-[10px] font-bold uppercase tracking-wider mb-3">
    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <rect x="2" y="4" width="20" height="16" rx="2" />
      <path d="M22 6l-10 7L2 6" />
    </svg>
    Newsletter
  </div>
  <h2 class="text-base font-bold leading-snug text-slate-900 mb-2">
    Maritime news in your inbox
  </h2>
  <p class="text-xs text-slate-700 leading-relaxed mb-4">
    Curated to topics you care about &mdash; P&amp;I, classification, sanctions, casualties. Daily or weekly. No account needed.
  </p>

  <form action="/newsletter/subscribe" method="POST" class="space-y-2">
    <input
      type="email"
      name="email"
      placeholder="you@example.com"
      autocomplete="email"
      required
      class="w-full px-3 py-2 rounded border border-slate-300 bg-white text-sm focus:outline-none focus:ring-2 focus:ring-sky-500"
    />
    <button
      type="submit"
      class="w-full px-3 py-2 rounded bg-sky-600 hover:bg-sky-700 text-white text-sm font-semibold transition shadow-sm"
    >
      Pick topics →
    </button>
  </form>

  <ul class="mt-4 space-y-1 text-[11px] text-slate-600">
    <li class="flex items-center gap-1.5">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-emerald-600 flex-shrink-0">
        <path d="M5 13l4 4L19 7" />
      </svg>
      Topic filtering
    </li>
    <li class="flex items-center gap-1.5">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-emerald-600 flex-shrink-0">
        <path d="M5 13l4 4L19 7" />
      </svg>
      Daily or weekly
    </li>
    <li class="flex items-center gap-1.5">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-emerald-600 flex-shrink-0">
        <path d="M5 13l4 4L19 7" />
      </svg>
      Unsubscribe one click
    </li>
  </ul>
</div>
